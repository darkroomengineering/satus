# ============================================
# SATŪS - Environment Variables
# ============================================
# Copy to .env.local: cp .env.example .env.local
# Only configure the integrations you need.
# Full reference: see integration READMEs in lib/integrations/*/
# ============================================

# --- Core ---
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
DRAFT_MODE_TOKEN=""

# --- Sanity CMS (https://sanity.io/manage) ---
# NEXT_PUBLIC_SANITY_PROJECT_ID=""
# NEXT_PUBLIC_SANITY_DATASET="production"
# NEXT_PUBLIC_SANITY_API_READ_TOKEN=""

# --- Shopify (https://shopify.dev/docs/storefronts/headless) ---
# SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
# SHOPIFY_STOREFRONT_ACCESS_TOKEN=""

# --- HubSpot (https://developers.hubspot.com/docs/api/overview) ---
# HUBSPOT_ACCESS_TOKEN=""
# NEXT_PUBLIC_HUBSPOT_PORTAL_ID=""

# --- Mailchimp (https://mailchimp.com/developer/) ---
# MAILCHIMP_API_KEY=""
# MAILCHIMP_SERVER_PREFIX=""
# MAILCHIMP_AUDIENCE_ID=""

# --- Analytics ---
# NEXT_PUBLIC_GOOGLE_ANALYTICS=""
# NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=""
