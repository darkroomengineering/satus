{
  "name": "@darkroom.engineering/satus",
  "description": "Next.js 16 starter by darkroom.engineering — React 19, TypeScript strict, Tailwind v4, Zod validation, and production-ready integrations",
  "version": "2.0.1",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "bun ./lib/scripts/dev.ts",
    "dev:https": "bun ./lib/scripts/dev.ts --https",
    "build": "bun run setup:styles && next build",
    "start": "next start",
    "preview": "bun run build && next start",
    "check": "biome check && bun node_modules/typescript7/bin/tsc --noEmit && bun test && bun run manifest:check",
    "clean": "rm -rf .next node_modules/.cache",
    "lint": "biome lint --max-diagnostics=200",
    "lint:fix": "biome lint --write --unsafe --max-diagnostics=200",
    "format": "biome format --write .",
    "typecheck": "bun node_modules/typescript7/bin/tsc --noEmit",
    "typecheck:watch": "bun node_modules/typescript7/bin/tsc --noEmit --watch",
    "deslop": "deslop",
    "analyze": "ANALYZE=true bun run build",
    "analyze:experimental": "next experimental-analyze",
    "dev:inspect": "bun ./lib/scripts/dev.ts --inspect",
    "lighthouse": "bunx @unlighthouse/cli --site http://localhost:3000",
    "setup:project": "bun ./lib/scripts/setup-project.ts",
    "satus": "bun ./lib/scripts/satus.ts",
    "test": "bun test",
    "test:e2e": "playwright test",
    "test:setup": "bun test lib/scripts/setup-project.test.ts",
    "doctor": "bun ./lib/scripts/doctor.ts",
    "setup:styles": "bun ./lib/styles/scripts/setup-styles.ts",
    "generate": "bun ./lib/scripts/generate.ts",
    "generate:manifest": "bun ./lib/scripts/generate-manifest.ts",
    "manifest:check": "bun ./lib/scripts/generate-manifest.ts --check",
    "handoff": "bun ./lib/scripts/prepare-handoff.ts",
    "sanity:extract": "cd lib/integrations/sanity && bun --env-file ../../../.env.local sanity schema extract",
    "sanity:typegen": "cd lib/integrations/sanity && bun --env-file ../../../.env.local sanity typegen generate && bun biome check --write --unsafe",
    "sanity:mcp": "bun ./lib/scripts/copy-sanity-mcp.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@portabletext/react": "^6.2.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@sanity/asset-utils": "^2.3.0",
    "@sanity/image-url": "^2.1.1",
    "@sanity/visual-editing": "^5.4.4",
    "@theatre/core": "^0.7.2",
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "hamo": "1.0.0-dev.13",
    "lenis": "^1.3.23",
    "next": "16.2.9",
    "next-sanity": "^13.1.1",
    "postprocessing": "^6.39.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tempus": "1.0.0-dev.18",
    "three": "0.185.0",
    "tunnel-rat": "^0.1.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@biomejs/biome": "2.5.1",
    "@clack/prompts": "^1.6.0",
    "@csstools/postcss-global-data": "^4.0.0",
    "@happy-dom/global-registrator": "^20.10.6",
    "@next/bundle-analyzer": "16.2.9",
    "@playwright/test": "1.61.1",
    "@sanity/vision": "^6.1.0",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/nextjs-vite": "^10.4.6",
    "@storybook/react": "^10.4.6",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@theatre/studio": "^0.7.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "deslop-cli": "0.7.3",
    "happy-dom": "^20.10.6",
    "lefthook": "^2.1.9",
    "postcss-functions": "^4.0.2",
    "postcss-preset-env": "^11.3.1",
    "react-scan": "^0.5.7",
    "sanity": "^6.1.0",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.3.1",
    "ts-morph": "^28.0.0",
    "typescript": "^6.0.3",
    "typescript7": "npm:typescript@^7.0.2"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "@swc/core",
    "@tailwindcss/oxide",
    "esbuild",
    "lefthook",
    "sharp"
  ],
  "overrides": {
    "lodash": "^4.17.21",
    "lodash-es": "^4.17.21"
  },
  "packageManager": "bun@1.3.5"
}
