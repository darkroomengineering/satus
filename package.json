{
  "name": "@darkroom.engineering/satus",
  "description": "React Router starter by darkroom.engineering — React 19, TypeScript strict, Tailwind v4, Zod validation",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "preview": "bun run build && bun run start",
    "check": "biome check && bun run typecheck && bun test",
    "clean": "rm -rf build node_modules/.cache .react-router",
    "lint": "biome lint --max-diagnostics=200",
    "lint:fix": "biome lint --write --unsafe --max-diagnostics=200",
    "format": "biome format --write .",
    "typecheck": "react-router typegen && tsc --noEmit",
    "test": "bun test",
    "setup:styles": "bun ./styles/scripts/setup-styles.ts"
  },
  "dependencies": {
    "@portabletext/react": "^6.0.3",
    "@react-router/node": "^7.13.1",
    "@react-router/serve": "^7.13.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@sanity/asset-utils": "^2.3.0",
    "@sanity/client": "^7.18.0",
    "@sanity/image-url": "^2.0.3",
    "@sanity/preview-url-secret": "^4.0.4",
    "@sanity/react-loader": "^2.0.8",
    "@sanity/visual-editing": "^5.3.1",
    "clsx": "^2.1.1",
    "groq": "^5.17.1",
    "gsap": "^3.14.2",
    "hamo": "1.0.0-dev.9",
    "isbot": "^5",
    "lenis": "^1.3.17",
    "postprocessing": "^6.38.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router": "^7.13.1",
    "tempus": "1.0.0-dev.17",
    "three": "0.182.0",
    "tunnel-rat": "^0.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@clack/prompts": "^1.0.0",
    "@csstools/postcss-global-data": "^4.0.0",
    "@hubspot/api-client": "^13.4.0",
    "@react-router/dev": "^7.13.1",
    "@sanity/vision": "^5.8.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@theatre/core": "^0.7.2",
    "@theatre/studio": "^0.7.2",
    "@types/bun": "^1.3.8",
    "@types/node": "^25.2.1",
    "@types/react": "19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.182.0",
    "@typescript/native-preview": "^7.0.0-dev.20260206.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "lefthook": "^2.1.0",
    "postcss-functions": "^4.0.2",
    "postcss-preset-env": "^11.1.3",
    "sanity": "^5.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-svgr": "^4.5.0"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "@swc/core",
    "@tailwindcss/oxide",
    "esbuild",
    "lefthook",
    "sharp"
  ],
  "overrides": {
    "lodash": "^4.17.21",
    "lodash-es": "^4.17.21"
  },
  "packageManager": "bun@1.3.5"
}
